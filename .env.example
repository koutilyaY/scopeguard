# ScopeGuard environment configuration.
# Copy to .env and adjust. Never commit .env.

# --- Core ---
ENVIRONMENT=development
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
API_PORT=8000
WEB_PORT=3000
# Host ports for the infra containers. Change these if another project on your machine
# already uses them (a clash surfaces as a confusing auth/connection error, because you
# end up talking to the other project's service).
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6380
MINIO_HOST_PORT=9002
MINIO_CONSOLE_HOST_PORT=9003
MAILPIT_HOST_PORT=8025
MAILPIT_SMTP_HOST_PORT=1025
OLLAMA_HOST_PORT=11435

# --- Database ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=scopeguard
POSTGRES_USER=scopeguard
POSTGRES_PASSWORD=scopeguard-dev-password
# Full override (takes precedence when set):
# DATABASE_URL=postgresql+psycopg://scopeguard:scopeguard-dev-password@postgres:5432/scopeguard

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- MinIO (S3-compatible object storage) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=scopeguard
MINIO_SECRET_KEY=scopeguard-dev-secret
MINIO_BUCKET=scopeguard-documents
MINIO_SECURE=false

# --- Local AI (Ollama) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
# Dimension of the embedding model above (nomic-embed-text = 768)
OLLAMA_EMBED_DIMENSIONS=768
OLLAMA_TIMEOUT_SECONDS=120
# LLM_PROVIDER=ollama REQUIRES a reachable Ollama with OLLAMA_CHAT_MODEL and
# OLLAMA_EMBED_MODEL pulled (`docker compose --profile ai up -d ollama`). Without it,
# reviews still produce their deterministic findings (duplicates/allowances/
# reconciliation) but are marked completed_with_errors and classify nothing.
# Set LLM_PROVIDER=fake to run entirely without Ollama (tests, evals and the no-AI demo
# do this — deterministic rules instead of a model; all money math is identical).
LLM_PROVIDER=ollama

# --- Auth & security ---
SESSION_TTL_MINUTES=480
SESSION_COOKIE_NAME=scopeguard_session
CSRF_COOKIE_NAME=scopeguard_csrf
COOKIE_SECURE=false            # set true behind TLS
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
PASSWORD_MIN_LENGTH=12
CORS_ORIGINS=http://localhost:3000

# --- Uploads ---
MAX_UPLOAD_BYTES=26214400      # 25 MiB

# --- Email (Mailpit, local only; the app NEVER auto-sends) ---
SMTP_HOST=mailpit
SMTP_PORT=1025

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
# Server-side URL the Next.js container uses to reach the API inside compose
API_INTERNAL_URL=http://api:8000
